' test
DEFINT A-Z
DIM X(100)
DIM Y(100)
DIM GRID(100,100)
TOPB=3
LEFTB=4
DEF FNX(IDX)=X(IDX)+LEFTB
DEF FNY(IDX)=Y(IDX)+TOPB
DEF FNCOLL(IDX)=GRID(X(IDX),Y(IDX))
GRID(10,30)=1
GRID(20,40)=2
X(1)=10
X(2)=20
Y(1)=30
Y(2)=40
TX1 = FNX(1)
TX2 = FNX(2)
TY1 = FNY(1)
TY2 = FNY(2)
TG1 = FNCOLL(1)
TG2 = FNCOLL(2)
PRINT "TX1 "; TX1
PRINT "TX2 "; TX2
PRINT "TY1 "; TY1
PRINT "TY2 "; TY2
PRINT "TG1 "; TG1
PRINT "TG2 "; TG2
END

